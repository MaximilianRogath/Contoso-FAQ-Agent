# ============================================================
#  .env.example  —  Environment variable template
#  Copy to .env and fill in your values
#
#  Authentication: all Azure resources use keyless auth
#  via Azure CLI. Run 'az login' before starting the agent.
#  No API keys required.
# ============================================================

# --- Microsoft Foundry (Agent Framework) --------------------
# Project endpoint from the Azure AI Foundry portal (Overview page)
AZURE_FOUNDRY_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# Model deployment name
AZURE_FOUNDRY_MODEL=gpt-4o

# --- Azure OpenAI (for embeddings) --------------------------
# Endpoint of your Azure OpenAI / Foundry resource
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Deployment name of the embedding model
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- Azure AI Search ----------------------------------------
# Endpoint of your Azure AI Search resource
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net

# Name of the index to create / use
AZURE_SEARCH_INDEX_NAME=faq-index
